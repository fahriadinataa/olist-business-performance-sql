-- Order Status Rate
-- Calculate the total percentage of orders by status
WITH order_status_rate AS(
SELECT 
	order_status,
    COUNT(order_id) AS total_order,
    ROUND(COUNT(order_id) * 100.0 / SUM(COUNT(order_id)) OVER(), 2) AS rate_order
FROM st_dim_order
GROUP BY order_status
ORDER BY FIELD(order_status, 
	'created', 
    'approved', 
    'invoiced', 
    'processing', 
    'shipped', 
    'delivered', 
    'canceled', 
    'unavailable'
))

-- Success Order vs Failed Order
SELECT *
FROM order_status_rate
WHERE order_status IN ('delivered', 'canceled', 'unavailable');


-- Overall Delivery Performance
SELECT 
    ROUND(AVG(DATEDIFF(delivered_date, purchase_date)), 2) AS avg_lead_time,
    MAX(DATEDIFF(delivered_date, purchase_date)) AS max_lead_time,
    MIN(DATEDIFF(delivered_date, purchase_date)) AS min_lead_time,
    MAX(DATEDIFF(delivered_date, estimated_date)) AS max_late_time,
    COUNT(DISTINCT CASE WHEN DATEDIFF(delivered_date, estimated_date) > 0 THEN order_id END) AS total_late_order,
    ROUND(COUNT(DISTINCT CASE WHEN DATEDIFF(delivered_date, estimated_date) > 0 THEN order_id END) * 100.0 /
	COUNT(DISTINCT CASE WHEN delivered_date IS NOT NULL THEN order_id END), 2) AS late_order_rate
FROM new_fact_order
WHERE delivered_date IS NOT NULL;


-- Late Order Distribution by Time Segment
WITH late_segment AS(
SELECT
	order_id,
    product_id,
    seller_id,
    qty_sold,
    total_payment AS total_gmv,
    DATEDIFF(delivered_date, estimated_date) AS late_time,
    CASE
		WHEN DATEDIFF(delivered_date, estimated_date) BETWEEN 1 AND 3 THEN '1 - 3 days late'
        WHEN DATEDIFF(delivered_date, estimated_date) BETWEEN 4 AND 7 THEN '4 - 7 days late'
        WHEN DATEDIFF(delivered_date, estimated_date) BETWEEN 8 AND 14 THEN '8 - 14 days late'
        WHEN DATEDIFF(delivered_date, estimated_date) > 14 THEN '14+ days late'
        END AS late_segment
FROM new_fact_order
WHERE DATEDIFF(delivered_date, estimated_date) > 0
)

SELECT 
	late_segment,
    COUNT(DISTINCT order_id) AS total_order
FROM late_segment
GROUP BY late_segment
ORDER BY total_order DESC;


