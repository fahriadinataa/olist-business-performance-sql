-- Customer Geographic Analysis
-- Customer Distribution by City and State
WITH customer_summary AS(
SELECT 
	o.customer_unique_id,
    c.customer_city,
    c.customer_state,
    COUNT(DISTINCT o.order_id) AS total_order,
    SUM(o.qty_sold) AS total_qty_sold,
    SUM(o.total_payment) AS total_gmv
FROM new_fact_order o
LEFT JOIN st_dim_customer c ON o.customer_unique_id = c.customer_unique_id
GROUP BY o.customer_unique_id, c.customer_city, c.customer_state
ORDER BY customer_unique_id
)

SELECT 
	customer_state,
    customer_city,
    SUM(total_order) AS total_order
FROM customer_summary
GROUP BY customer_state, customer_city
ORDER BY total_order DESC;


-- Seller Geographic Analysis
-- Seller by State and City
SELECT 
	s.seller_state,
    s.seller_city,
    COUNT(DISTINCT s.seller_id) AS total_seller,
    ROUND(SUM(total_payment), 2) AS total_gmv
FROM new_fact_order o
LEFT JOIN st_dim_seller s ON o.seller_id = s.seller_id
GROUP BY s.seller_state, s.seller_city
ORDER BY total_seller DESC;



