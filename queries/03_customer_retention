-- Delivery Performance Impact Analysis
SELECT 
    c.segment,
    ROUND(AVG(DATEDIFF(f.delivered_date, f.purchase_date)), 2) AS avg_lead_time,
    MAX(DATEDIFF(f.delivered_date, f.purchase_date)) AS max_lead_time,
    MAX(DATEDIFF(f.delivered_date, f.estimated_date)) AS max_late_time,
	ROUND(COUNT(DISTINCT CASE WHEN DATEDIFF(f.delivered_date, f.estimated_date) > 0 THEN order_id END) * 100.0 /
    COUNT(DISTINCT f.order_id), 2) AS late_time_rate,
    COUNT(DISTINCT CASE WHEN DATEDIFF(f.delivered_date, f.estimated_date) > 0 THEN order_id END) AS total_late_delivery,
    COUNT(DISTINCT CASE WHEN DATEDIFF(f.delivered_date, f.estimated_date) > 10 THEN order_id END) AS late_delivery_10days_up
FROM new_fact_order f
JOIN customer_segment c ON f.customer_unique_id = c.customer_unique_id
WHERE delivered_date IS NOT NULL
GROUP BY c.segment;
