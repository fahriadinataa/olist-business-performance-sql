-- Retention Segment Analysis
DROP TEMPORARY TABLE IF EXISTS customer_segment;

CREATE TEMPORARY TABLE customer_segment
SELECT 
	customer_unique_id,
    MIN(purchase_date) AS first_order_date,
    MAX(purchase_date) AS last_order_date,
    COUNT(DISTINCT order_id) AS total_order,
    SUM(qty_sold) AS total_qty_sold,
    SUM(total_payment) AS total_gmv,
	CASE
		WHEN MIN(purchase_date) != MAX(purchase_date) THEN 'repeat customer'
		WHEN MIN(purchase_date) = MAX(purchase_date) 
			AND MAX(purchase_date) <= DATE_SUB((SELECT MAX(purchase_date) FROM order_valid_summary), INTERVAL 5 MONTH) THEN 'churn customer'
        -- I used 5 month based on average number of days until a customer places a repeat order
        ELSE 'one-time customer'
        END AS segment
FROM new_fact_order o
GROUP BY o.customer_unique_id
ORDER BY segment;

SELECT *
FROM customer_segment;
-- Repeat Customer : Customers who have placed more than one order
-- Churn Customer : Customers who have placed only one order, and that order was placed more than five months ago
-- Onetime Customer : Customers who have placed only one order, and that order was placed within the last five months

SELECT
	segment,
    COUNT(DISTINCT customer_unique_id) AS total_customer,
    ROUND(COUNT(DISTINCT customer_unique_id) * 100.0 / SUM(COUNT(*)) OVER(), 2) AS segment_rate,
    SUM(total_qty_sold) AS total_qty_sold,
    ROUND(SUM(total_gmv), 2) AS total_gmv,
    ROUND(SUM(total_gmv) * 100.0 / SUM(SUM(total_gmv)) OVER(), 2) AS gmv_contribution
FROM customer_segment
GROUP BY segment;
