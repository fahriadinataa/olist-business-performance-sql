-- Category Preference by Retention Segment
-- Compare the product categories purchased by churned customers and repeat customers
WITH product_by_segment AS(
SELECT 
	c.segment,
    p.product_category_name AS category_name,
    COUNT(DISTINCT order_id) AS total_order,
    ROW_NUMBER() OVER(PARTITION BY c.segment ORDER BY COUNT(DISTINCT order_id) DESC) AS rank_total_order
FROM new_fact_order o
LEFT JOIN customer_segment c ON o.customer_unique_id = c.customer_unique_id
LEFT JOIN st_dim_product p ON o.product_id = p.product_id
GROUP BY segment, category_name
ORDER BY segment, rank_total_order ASC
)

SELECT 
	segment,
    category_name,
    total_order
FROM product_by_segment
WHERE rank_total_order <= 5
	AND segment IN ('churn customer' AND 'repeat customer');
