-- Cohort Analysis
-- Create First Order Table
-- To find out the date of the customer's first order
DROP TEMPORARY TABLE IF EXISTS first_order;

CREATE TEMPORARY TABLE first_order
SELECT 
	customer_unique_id,
    MIN(purchase_date) AS first_purchase,
    DATE_FORMAT(MIN(purchase_date), '%Y-%m') AS cohort_month
FROM new_fact_order 
GROUP BY customer_unique_id
ORDER BY first_purchase;

SELECT *
FROM first_order;
--

-- Create Cohort Base Table
-- To identify customers who have placed more than one order and the number of months between orders
DROP TEMPORARY TABLE IF EXISTS cohort_base;

CREATE TEMPORARY TABLE cohort_base
SELECT 
	o.customer_unique_id,
    f.cohort_month,
    DATE_FORMAT(o.purchase_date, '%Y-%m') AS order_month,
    (YEAR(o.purchase_date)*12 + MONTH(o.purchase_date)) -
    (YEAR(f.first_purchase)*12 + MONTH(f.first_purchase)) AS cohort_age,
    COUNT(DISTINCT o.order_id) AS total_order,
    ROUND(SUM(o.qty_sold), 2) AS total_qty_sold,
    ROUND(SUM(o.total_payment), 2) AS total_gmv
FROM new_fact_order o
LEFT JOIN first_order f ON o.customer_unique_id = f.customer_unique_id
GROUP BY 
	o.customer_unique_id,
    f.cohort_month,
    DATE_FORMAT(o.purchase_date, '%Y-%m'),
    cohort_age
ORDER BY o.customer_unique_id;

SELECT AVG(cohort_age) AS avg_repeat_order
FROM cohort_base
WHERE cohort_age != 0
ORDER BY customer_unique_id;
-- The average number of months until a customer places a repeat order is 4.8 month


-- To determine the number of customers who are still active after their first order
-- Calculated on a monthly basis
WITH cohort_matrix AS(
SELECT 
	cohort_month,
	cohort_age,
    COUNT(DISTINCT customer_unique_id) AS active_cust,
    ROUND(COUNT(DISTINCT customer_unique_id) * 100.0 /
    FIRST_VALUE(COUNT(DISTINCT customer_unique_id))
    OVER(PARTITION BY cohort_month ORDER BY cohort_age), 2) AS retention_rate
FROM cohort_base
GROUP BY cohort_month, cohort_age
ORDER BY cohort_month
)

-- Create a cohort summary table using the retention rate metric
SELECT 
	cohort_month,
    MAX(CASE WHEN cohort_age = 0 THEN retention_rate END) AS month_0,
    MAX(CASE WHEN cohort_age = 1 THEN retention_rate END) AS month_1,
    MAX(CASE WHEN cohort_age = 2 THEN retention_rate END) AS month_2,
    MAX(CASE WHEN cohort_age = 3 THEN retention_rate END) AS month_3,
    MAX(CASE WHEN cohort_age = 4 THEN retention_rate END) AS month_4,
    MAX(CASE WHEN cohort_age = 5 THEN retention_rate END) AS month_5,
    MAX(CASE WHEN cohort_age = 6 THEN retention_rate END) AS month_6,
    MAX(CASE WHEN cohort_age = 7 THEN retention_rate END) AS month_7,
    MAX(CASE WHEN cohort_age = 8 THEN retention_rate END) AS month_8,
    MAX(CASE WHEN cohort_age = 9 THEN retention_rate END) AS month_9,
    MAX(CASE WHEN cohort_age = 10 THEN retention_rate END) AS month_10,
    MAX(CASE WHEN cohort_age = 11 THEN retention_rate END) AS month_11,
    MAX(CASE WHEN cohort_age = 12 THEN retention_rate END) AS month_12,
    MAX(CASE WHEN cohort_age = 13 THEN retention_rate END) AS month_13,
    MAX(CASE WHEN cohort_age = 14 THEN retention_rate END) AS month_14,
    MAX(CASE WHEN cohort_age = 15 THEN retention_rate END) AS month_15,
    MAX(CASE WHEN cohort_age = 16 THEN retention_rate END) AS month_16,
    MAX(CASE WHEN cohort_age = 17 THEN retention_rate END) AS month_17,
    MAX(CASE WHEN cohort_age = 18 THEN retention_rate END) AS month_18,
    MAX(CASE WHEN cohort_age = 19 THEN retention_rate END) AS month_19,
    MAX(CASE WHEN cohort_age = 20 THEN retention_rate END) AS month_20
FROM cohort_matrix
GROUP BY cohort_month
ORDER BY cohort_month;
