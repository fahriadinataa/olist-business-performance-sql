DROP TEMPORARY TABLE IF EXISTS product_summary;

CREATE TEMPORARY TABLE product_summary
SELECT
	order_id,
	product_id,
	category_name,
	seller_id,
	customer_unique_id,
	qty_sold,
	price,
	freight_value,
	total_price,
	total_gmv
FROM
	(SELECT
		o.order_id,
		o.product_id,
		p.product_category_name AS category_name,
		o.seller_id,
		o.customer_unique_id,
		o.qty_sold,
		i.price,
		i.freight_value,
		o.actual_price AS total_price,
		o.total_payment AS total_gmv,
    ROW_NUMBER() OVER(
    PARTITION BY order_id, product_id, seller_id, customer_unique_id) AS check_dup
	FROM new_fact_order o
	LEFT JOIN st_fact_item i ON o.order_id = i.order_id
		AND o.product_id = i.product_id
		AND o.seller_id = i.seller_id
	LEFT JOIN st_dim_product p ON o.product_id = p.product_id
) s
WHERE check_dup = 1;
-- Returns the real price for each product


-- Top 5 products contributing the most to total GMV
SELECT 
    category_name,
    ROUND(AVG(price), 2) AS avg_price,
    ROUND(SUM(total_gmv), 2) AS gmv_value
FROM product_summary 
GROUP BY category_name
ORDER BY gmv_value DESC
LIMIT 5;
--

-- 5 best-selling category
SELECT 
    category_name,
    ROUND(AVG(price), 2) AS avg_price,
    COUNT(DISTINCT order_id) AS total_order
FROM product_summary 
GROUP BY category_name
ORDER BY total_order DESC
LIMIT 5;
--

-- Price Distribution Product Category 
SELECT 
	category_name,
	MAX(price) AS max_price,
    MIN(price) AS min_price,
    ROUND(AVG(price), 2) AS avg_price
FROM product_summary
GROUP BY category_name
ORDER BY avg_price DESC;
--

-- Top 10 Category-Seller Combinations with Lowest Review Score (min. 500 orders)
SELECT 
	p.category_name,
    p.seller_id,
    COUNT(DISTINCT p.order_id) AS total_order,
    ROUND(AVG(r.review_score), 2) AS avg_review_score
FROM product_summary p
LEFT JOIN st_dim_review r ON p.order_id = r.order_id
GROUP BY p.category_name, p.seller_id
HAVING total_order > 500
ORDER BY avg_review_score
LIMIT 10;
