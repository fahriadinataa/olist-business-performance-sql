-- Distribution of review scores among sellers 
-- Segmentation of sellers based on average review scores and total orders
DROP TEMPORARY TABLE IF EXISTS segment_performance;

CREATE TEMPORARY TABLE segment_performance
SELECT 
	o.seller_id,
    AVG(r.review_score) AS avg_review_score,
    COUNT(DISTINCT o.order_id) AS total_order,
    COUNT(DISTINCT o.customer_unique_id) AS total_customer,
    CASE
		WHEN AVG(r.review_score) > 4.0 AND COUNT(DISTINCT o.order_id) > 500 THEN 'top seller'
        WHEN AVG(r.review_score) > 4.0 AND COUNT(DISTINCT o.order_id) < 500 
        AND COUNT(DISTINCT o.order_id) > 100 THEN 'potential seller'
        WHEN AVG(r.review_score) < 4.0 AND COUNT(DISTINCT o.order_id) > 500 THEN 'risky seller'
        ELSE 'underperformed'
        END AS segment
FROM new_fact_order o
LEFT JOIN st_dim_review r ON o.order_id = r.order_id
GROUP BY o.seller_id
ORDER BY total_order DESC;
