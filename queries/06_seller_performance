-- Top 10 sellers based on their GMV contribution to the total
DROP TEMPORARY TABLE IF EXISTS seller_summary;

CREATE TEMPORARY TABLE seller_summary
SELECT 
	s.seller_id,
    s.seller_city,
    s.seller_state,
    COUNT(DISTINCT o.order_id) AS total_order,
    COUNT(DISTINCT o.customer_unique_id) AS total_customer,
    COUNT(DISTINCT o.product_id) AS total_product,
    SUM(o.qty_sold) AS total_qty_sold,
    ROUND(SUM(o.total_payment), 2) AS total_gmv,
    ROUND(SUM(o.total_payment) * 100.0 / SUM(SUM(o.total_payment)) OVER(), 2) AS gmv_contribution
FROM new_fact_order o
LEFT JOIN st_dim_seller s ON o.seller_id = s.seller_id
GROUP BY s.seller_id, s.seller_city, s.seller_state
ORDER BY gmv_contribution DESC;

SELECT *
FROM seller_summary
ORDER BY total_gmv DESC
LIMIT 10;
--

-- Top 10 of Sellers With The Most Repeat Orders 
SELECT 
	seller_id,
    total_order - total_customer AS repeat_order
FROM seller_summary
ORDER BY repeat_order DESC
LIMIT 10;
