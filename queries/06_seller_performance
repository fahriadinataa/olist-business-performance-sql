-- Late Order Rate by Seller Segment
WITH seller_stats AS(
SELECT 
	seller_id,
	COUNT(DISTINCT order_id) AS total_order,
	COUNT(DISTINCT CASE 
		WHEN delivered_date IS NOT NULL 
			AND DATEDIFF(delivered_date, estimated_date) > 0 
			THEN order_id 
		END) AS total_late_order,
	MAX(CASE 
		WHEN delivered_date IS NOT NULL 
			THEN DATEDIFF(delivered_date, estimated_date) 
		END) AS max_late_time
FROM new_fact_order
GROUP BY seller_id
ORDER BY total_late_order DESC
)

SELECT 
    s.seller_id,
    p.segment,
    s.total_order,
    s.total_late_order,
    ROUND(s.total_late_order * 100.0 / s.total_order, 2) AS late_time_rate,
    s.max_late_time
FROM seller_stats s
JOIN segment_performance p ON s.seller_id = p.seller_id
WHERE s.total_order > 100
ORDER BY late_time_rate DESC;
